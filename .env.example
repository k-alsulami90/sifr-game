# Firebase web app config — copy this file to `.env.local` and fill in your
# own project's values (Firebase console → Project settings → "Your apps").
# All keys must be prefixed with VITE_ so Vite exposes them to the client.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
